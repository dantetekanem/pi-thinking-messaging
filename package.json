{
  "name": "pi-thinking-messaging",
  "version": "0.1.3",
  "description": "Pi extension that adds elapsed time, directional tokens, and idle notices to Pi's original working/thinking loader.",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "keywords": [
    "pi-package",
    "pi-extension",
    "thinking",
    "working-message",
    "tokens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dantetekanem/pi-thinking-messaging.git"
  },
  "bugs": {
    "url": "https://github.com/dantetekanem/pi-thinking-messaging/issues"
  },
  "homepage": "https://github.com/dantetekanem/pi-thinking-messaging#readme",
  "files": [
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
